{
    "include": [
        "src",
        "tests"
    ],
    "exclude": [
        "venv",
        "build",
        "dist",
        "htmlcov",
        "**/__pycache__",
        "**/*.egg-info",
        "src/accessiweather/weather_gov_api_client/models",
        "src/accessiweather/weatherapi_client"
    ],
    "ignore": [
        "venv/**",
        "build/**",
        "dist/**"
    ],
    "reportMissingImports": true,
    "reportMissingTypeStubs": false,
    "pythonVersion": "3.12",
    "pythonPlatform": "Windows"
}
